# =========================
# Django
# =========================
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3007,http://127.0.0.1:3000
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3007,http://127.0.0.1:3000

# =========================
# PostgreSQL (main/dev DB)
# =========================
DB_NAME=aimon_db
DB_USER=YOUR_USER
DB_PASSWORD=YOUR_PASSWORD
DB_HOST=192.168.99.138
DB_PORT=5432

# =========================
# PostgreSQL (test DB)
# - must be different from DB_NAME
# =========================
TEST_DB_NAME=aimon_test_db
TEST_DB_USER=YOUR_USER
TEST_DB_PASSWORD=YOUR_PASSWORD
TEST_DB_HOST=192.168.99.138
TEST_DB_PORT=5432

# =========================
# Next.js
# =========================
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# =========================
# Optional (future use)
# =========================
OCR_PROVIDER=stub
OCR_API_KEY=
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
